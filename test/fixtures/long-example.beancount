    <style>
      .user-mention[href$="/thanos"] {
        color: var(--color-user-mention-fg);
        background-color: var(--bgColor-attention-muted, var(--color-attention-subtle));
        border-radius: 2px;
        margin-left: -2px;
        margin-right: -2px;
      }
      .user-mention[href$="/thanos"]:before,
      .user-mention[href$="/thanos"]:after {
        content: '';
        display: inline-block;
        width: 2px;
      }
    </style>


